# Auto-detect text files and normalize to LF
* text=auto

# Windows-specific scripts
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Shell scripts
*.sh text eol=lf

# Always LF for source code
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Binary files - never modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.dll binary
*.exe binary
*.pdb binary
*.tlb binary
*.pfx binary
*.zip binary
*.db binary
*.sqlite binary
*.sqlite3 binary
